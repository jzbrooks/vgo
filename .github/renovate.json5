{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [ "config:recommended" ],
  automergeType: "pr",
  automergeStrategy: "rebase",
  packageRules: [
    {
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
    },
    {
      groupName: "kotlin",
      matchPackagePrefixes: ["org.jetbrains.kotlin"],
    },
  ]
}
